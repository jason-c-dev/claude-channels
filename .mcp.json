{
  "mcpServers": {
    "voice-tools": {
      "command": "bun",
      "args": ["run", "tools/voice-tools/src/index.ts"],
      "env": {
        "STT_MODEL": "/opt/homebrew/share/whisper-cpp/models/ggml-base.en.bin"
      }
    },
    "webhook-channel": {
      "command": "bun",
      "args": ["run", "channels/webhook-channel/src/index.ts"],
      "env": {
        "WEBHOOK_PORT": "8788"
      }
    }
  }
}
